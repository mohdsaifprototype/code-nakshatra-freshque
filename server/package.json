    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
